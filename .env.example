# Jarvis AI Configuration File
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control

# ============================================
# Google Gemini API Configuration (REQUIRED for AI responses)
# ============================================
# Get your API key from: https://console.cloud.google.com/
# 1. Create a Google Cloud project
# 2. Enable the Generative Language API
# 3. Create an API key in Credentials
# 4. Copy the key and paste it below

GEMINI_API_KEY=your_actual_api_key_here

# ============================================
# Django Settings
# ============================================
DEBUG=False
SECRET_KEY=your-secret-key-here
ALLOWED_HOSTS=localhost,127.0.0.1

# Database Configuration (optional - defaults to SQLite)
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=jarvis_db
# DB_USER=postgres
# DB_PASSWORD=password
# DB_HOST=localhost
# DB_PORT=5432

# ============================================
# Desktop Application Configuration
# ============================================

# Use Vosk for offline speech recognition (True = offline, False = online)
USE_OFFLINE_MODE=True

# Path to Vosk model (relative to project root)
VOSK_MODEL_PATH=jarvis_desktop/models/vosk-model-en-us-0.42-gigaspeech

# Voice type: 'female' or 'male'
TTS_VOICE_TYPE=female

# Speech rate (0.5 = slow, 1.0 = normal, 2.0 = fast)
TTS_RATE=1.0

# Volume (0.0 to 1.0)
TTS_VOLUME=0.9

# Timeout for speech recognition in seconds
SPEECH_TIMEOUT=10

# Confidence threshold for recognition (0.0 to 1.0)
SPEECH_CONFIDENCE=0.5

# Enable voice waveform visualization
ENABLE_VISUALIZATION=False

# Sync desktop commands with Django web app
SYNC_WITH_DJANGO=True

# Django API endpoint
DJANGO_API_URL=http://localhost:8000/api

# Command history file
COMMAND_HISTORY_FILE=jarvis_desktop/command_history.json

# ============================================
# Application Settings
# ============================================
LOG_LEVEL=INFO
RATE_LIMIT_ENABLED=False
SESSION_TIMEOUT=3600

# Security Settings (Production)
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
CSRF_TRUSTED_ORIGINS=http://localhost:8000

# ============================================
# Optional: Legacy Configuration
# ============================================
# Email Configuration (optional)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# Webhook Configuration (optional)
WEBHOOK_URL=https://your-webhook-endpoint.com/webhook
# AWS_ACCESS_KEY_ID=your-aws-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret
# AWS_STORAGE_BUCKET_NAME=your-bucket-name
# AWS_S3_REGION_NAME=us-east-1
