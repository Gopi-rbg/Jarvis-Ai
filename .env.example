# Jarvis AI Voice Assistant - Environment Configuration
# Copy this file to .env and fill in with your values

# Django Settings
DEBUG=True
SECRET_KEY=your-secret-key-here
ALLOWED_HOSTS=localhost,127.0.0.1

# Database Configuration (optional - defaults to SQLite)
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=jarvis_db
# DB_USER=postgres
# DB_PASSWORD=password
# DB_HOST=localhost
# DB_PORT=5432

# OpenAI Configuration (optional)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Weather API (optional)
WEATHER_API_KEY=your-openweathermap-api-key

# Webhook Configuration (optional)
WEBHOOK_URL=https://your-webhook-endpoint.com/webhook

# Email Configuration (optional)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# Jarvis Configuration
JARVIS_WAKE_WORD=jarvis
JARVIS_RESPONSE_TIMEOUT=10
JARVIS_MAX_AUDIO_LENGTH=30

# Application Settings
LOG_LEVEL=INFO
RATE_LIMIT_ENABLED=False
SESSION_TIMEOUT=3600

# Security Settings (Production)
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
CSRF_TRUSTED_ORIGINS=http://localhost:8000

# Amazon S3 Configuration (for static files storage)
# AWS_ACCESS_KEY_ID=your-aws-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret
# AWS_STORAGE_BUCKET_NAME=your-bucket-name
# AWS_S3_REGION_NAME=us-east-1
